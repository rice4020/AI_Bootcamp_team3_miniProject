# NeonDB PostgreSQL Connection String
# Neon Console (https://console.neon.tech) 에서 프로젝트의 Connection Details를 찾아 대입하세요.
# 예시: postgresql://[user]:[password]@[neon-host]/[dbname]?sslmode=require
DATABASE_URL="postgresql://username:password@your-neon-hostname.neon.tech/neondb?sslmode=require"

# ==========================================
# 🔑 서비스 API 연동 키 (API KEYS CONFIG)
# ==========================================

# 1. 공공데이터포털 일반인증키 (기상청 및 전국문화축제 API 공동 사용)
# 공공데이터포털(https://www.data.go.kr)에서 해당 API를 신청한 뒤 받은 일반인증키를 대입하세요.
PUBLIC_DATA_API_SERVICE_KEY="your-public-data-api-service-key"

# 2. SNS 홍보 문구 및 상권 분석용 AI API Key (Claude 등)
# API 키를 발급받아 아래에 대입하면 무료 폴백 모드에서 AI 모드로 자동 전환됩니다.
SNS_AI_API_KEY="your-sns-ai-api-key"

# 3. 소상공인시장진흥공단 상가(상권)정보 API 일반 인증키
# 공공데이터포털(data.go.kr)에서 발급받으신 서비스 일반 인증키(Service Key)를 기입해 주세요.
KOREA_COMMERCIAL_API_KEY="your-commercial-api-key"
